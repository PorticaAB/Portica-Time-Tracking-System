# --- Database (Neon Postgres) ---
# Neon gives you two connection strings: a pooled one (via PgBouncer, hostname
# ends in "-pooler") for the app at runtime, and a direct one for migrations.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require"

# --- Auth ---
# Generate with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- CORS ---
# The deployed client URL(s), comma-separated if more than one (e.g. a Vercel
# preview + production domain). No trailing slash.
CORS_ORIGIN="https://your-app.vercel.app"

# --- Server ---
# Railway sets this automatically - only needed for local dev.
PORT=4000

# --- Email (Resend) ---
# The deployed client URL - used to build reset/invite links in emails.
APP_URL="https://your-app.vercel.app"
# From Resend: Domains -> add + verify yours, then API Keys -> create one.
# Leave both unset to run without real email - forgot-password/invite
# endpoints still work, returning the raw link in the API response instead
# (see server/src/lib/email.ts).
RESEND_API_KEY=""
EMAIL_FROM="Klocka <noreply@yourdomain.com>"
