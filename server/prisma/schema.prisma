generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  CONTRACTOR
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CONTRACTOR)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments  ProjectAssignment[]
  timeEntries  TimeEntry[]

  @@map("users")
}

model Client {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projects  Project[]

  @@map("clients")
}

model Project {
  id            String   @id @default(cuid())
  name          String
  clientId      String
  isActive      Boolean  @default(true)
  billableRate  Decimal? @db.Decimal(10, 2)
  currency      String?  @default("SEK")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client        Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks         Task[]
  assignments   ProjectAssignment[]
  timeEntries   TimeEntry[]

  @@index([clientId])
  @@map("projects")
}

// Contractors assigned to a project - controls who can log time against it
model ProjectAssignment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_assignments")
}

// Project-scoped premade task labels (e.g. "Design", "Client Call")
model Task {
  id        String   @id @default(cuid())
  name      String
  projectId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("tasks")
}

model TimeEntry {
  id          String    @id @default(cuid())
  userId      String
  projectId   String
  taskId      String?
  description String    @default("")
  startTime   DateTime
  endTime     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([startTime])
  @@map("time_entries")
}

model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
  @@map("holidays")
}
