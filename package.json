{
  "name": "klocka",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace klocka-server",
    "dev:client": "npm run dev --workspace klocka-client",
    "build:server": "npm run build --workspace klocka-server",
    "build:client": "npm run build --workspace klocka-client",
    "prisma:generate": "npm run prisma:generate --workspace klocka-server",
    "prisma:migrate": "npm run prisma:migrate --workspace klocka-server",
    "seed": "npm run seed --workspace klocka-server"
  }
}
