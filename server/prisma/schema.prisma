generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  CONTRACTOR
}

// Free-text-ish label for how a non-admin user is shown in the UI ("Team
// Member" vs "Coach"). Orthogonal to Role, which still governs access.
enum MemberRole {
  TEAM_MEMBER
  COACH
}

enum TokenPurpose {
  PASSWORD_RESET
  INVITE
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String
  phone        String?
  role         Role        @default(CONTRACTOR)
  memberRole   MemberRole? @default(TEAM_MEMBER)
  isActive     Boolean     @default(true)
  // Null = invited but hasn't set their own password yet. Set immediately for
  // accounts created directly (seed/admin), and on successful invite acceptance.
  activatedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  timeEntries     TimeEntry[]
  taskAssignments TaskAssignment[]
  authTokens      AuthToken[]

  @@map("users")
}

// Password-reset and invite-to-set-password links. Only a SHA-256 hash of the
// raw token is stored - the raw value only ever exists in the emailed link.
model AuthToken {
  id        String       @id @default(cuid())
  userId    String
  tokenHash String       @unique
  purpose   TokenPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("auth_tokens")
}

model Client {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  // Marks the single system-managed "Unassigned" bucket that absorbs time
  // entries orphaned by a permanent project/client delete. Hidden from
  // listings and immune to further edit/delete.
  isSystem  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projects  Project[]

  @@map("clients")
}

model Project {
  id            String   @id @default(cuid())
  name          String
  clientId      String
  isActive      Boolean  @default(true)
  isSystem      Boolean  @default(false)
  billableRate  Decimal? @db.Decimal(10, 2)
  currency      String?  @default("SEK")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client        Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks         Task[]
  timeEntries   TimeEntry[]

  @@index([clientId])
  @@map("projects")
}

// Project-scoped premade task labels (e.g. "Design", "Client Call").
// Admins can assign specific tasks to specific team members; a task with no
// assignments is open to everyone (see TaskAssignment).
model Task {
  id        String   @id @default(cuid())
  name      String
  projectId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]
  assignments TaskAssignment[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("tasks")
}

model TaskAssignment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_assignments")
}

model TimeEntry {
  id          String    @id @default(cuid())
  userId      String
  projectId   String
  taskId      String?
  description String    @default("")
  startTime   DateTime
  endTime     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([startTime])
  @@map("time_entries")
}

model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
  @@map("holidays")
}
